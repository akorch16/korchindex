# Primary Postgres (writes + live-prices reads)
DATABASE_URL=postgresql://korch:korch@localhost:5432/korchindex
# Read replica (Phase 5). Leave unset to route all reads to the primary.
#DATABASE_URL_REPLICA=postgresql://korch:korch@localhost:5433/korchindex
# Redis (Phase 2 cache-aside). Optional in Phase 1.
REDIS_URL=redis://localhost:6379/0
# Comma-separated CORS origins
CORS_ORIGINS=https://akorch16.github.io,http://localhost:5173
